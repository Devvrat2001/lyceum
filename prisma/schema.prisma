// Lyceum — Phase 1 schema (Identity + Catalog + Progress)
// See AGENT_NOTES.md § Database schema for the complete plan.
// Social/Commerce/Safety models are deferred to later phases.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────── Identity ───────────────────────────

enum Role {
  STUDENT
  TEACHER
  ADMIN
  PARENT
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum BlockType {
  VIDEO
  READING
  SLIDES
  PDF
  QUIZ
  MCQ
  SPEAK
  AI_QUIZ
  SIMULATION
  BRANCHING
  DRAG_MATCH
  POLL
  SECTION
  DISCUSSION
  LIVE
}

model User {
  id             String      @id @default(cuid())
  email          String      @unique
  emailVerified  DateTime?
  passwordHash   String?     // bcrypt; null = no password set (seeded demo user, dev-quick-login only)
  name           String?
  firstName      String?
  avatarUrl      String?
  // Auth.js standard field. The Prisma adapter writes `image` on OAuth
  // first sign-in (createUser); without this column Google/SSO sign-in
  // 500s. App UI prefers `avatarUrl ?? image` for the display avatar.
  image          String?
  // Teacher storefront — public profile presentation. Both optional;
  // a teacher who hasn't customized their storefront falls back to
  // just their name + published course list.
  headline       String?
  bio            String?     @db.Text
  role           Role        @default(STUDENT)
  institutionId  String?
  institution    Institution? @relation(fields: [institutionId], references: [id])
  classId        String?
  class          Class?      @relation("ClassStudents", fields: [classId], references: [id])
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Phase 6 — self-serve account settings (/settings page).
  // Transactional mail (receipts) always sends; this gates the optional
  // weekly digest + re-engagement nudges.
  emailOptOut    Boolean     @default(false)
  // COPPA/FERPA: when set, the AI tutor does NOT persist conversation
  // content (the session shell + rate-limit accounting still work).
  tutorLogOptOut Boolean     @default(false)
  // When the user acknowledged data / AI-processing consent (self-serve).
  coppaConsentAt DateTime?

  // Auth.js relations
  accounts       Account[]
  sessions       Session[]

  // Domain
  enrollments    Enrollment[]
  attempts       Attempt[]
  xpEvents       XPEvent[]
  streak         Streak?
  badges         UserBadge[]
  notifications  Notification[]
  tutorSessions  TutorSession[]
  reviews        Review[]
  follows        Follow[]    @relation("Follower")
  followers      Follow[]    @relation("Followed")
  authoredCourses Course[]   @relation("CourseAuthor")
  taughtClasses  Class[]     @relation("ClassTeacher")
  mastery        Mastery[]
  // Phase 3 — payments
  ordersBought   Order[]     @relation("OrderBuyer")
  ordersSold     Order[]     @relation("OrderTeacher")
  stripeAccount  StripeAccount?
  blockVotes     BlockVote[]
  blockComments  BlockComment[]
  // Phase 4 — parent role: a PARENT user's links to their STUDENT
  // kids, and a STUDENT user's reverse link back to their parents.
  childLinks     ParentChild[] @relation("ParentLinks")
  parentLinks    ParentChild[] @relation("ChildLinks")
  // Per-lesson completion checkpoints — drive Enrollment.progressPct.
  lessonProgress LessonProgress[]
  // Background AI generation jobs (outline, regenerate, …). One row per
  // job kicked off by this user; survives until manually cleaned up.
  generationJobs GenerationJob[]

  @@index([role])
}

// Auth.js v5 standard tables
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Institution {
  id        String  @id @default(cuid())
  slug      String  @unique
  name      String
  plan      String  @default("FREE")
  seats     Int     @default(0)
  users     User[]
  classes   Class[]
  createdAt DateTime @default(now())
}

model Class {
  id            String      @id @default(cuid())
  institutionId String
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  name          String
  teacherId     String?
  teacher       User?       @relation("ClassTeacher", fields: [teacherId], references: [id])
  students      User[]      @relation("ClassStudents")
  createdAt     DateTime    @default(now())
  @@unique([institutionId, name])
}

// ─────────────────────────── Catalog ───────────────────────────

model Course {
  id           String       @id @default(cuid())
  slug         String       @unique
  title        String
  tagline      String?
  description  String       @db.Text
  thumbnailUrl String?
  authorId     String
  author       User         @relation("CourseAuthor", fields: [authorId], references: [id])
  authorLabel  String?      // free-form display name (e.g., "Khan Edu Group")
  subject      String       // "math"
  grade        String       // "6"
  status       CourseStatus @default(DRAFT)
  priceCents   Int          @default(0)
  ratingAvg    Float        @default(0)
  ratingCount  Int          @default(0)
  enrollCount  Int          @default(0)
  tag          String?      // "BESTSELLER", "NEW", ...
  aiHint       String?      @db.Text
  learnOutcomes Json?       // string[]
  upgradeNote  String?
  units        Unit[]
  reviews      Review[]
  enrollments  Enrollment[]
  pathLinks    PathCourse[]
  orders       Order[]      @relation("OrderCourse")
  publishedAt  DateTime?
  updatedAt    DateTime     @updatedAt
  createdAt    DateTime     @default(now())
  // Semantic search vector: OpenAI text-embedding-3-small output of
  // `title + tagline + description + subject + grade`. Populated via
  // a fire-and-forget hook on course create/update; pgvector handles
  // the similarity search in `marketplace.semanticSearch`. Nullable so
  // rows can exist before the embedding lands (we backfill in batches);
  // unembedded courses just don't appear in semantic results until then.
  // Stored via raw SQL — pgvector has no Prisma-native type.
  embedding    Unsupported("vector(1536)")?
  @@index([subject, grade, status])
}

model Unit {
  id        String   @id @default(cuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  order     Int
  title     String
  subtitle  String?
  estLabel  String?  // e.g., "6 lessons · 1h 50m"
  lessons   Lesson[]
  @@index([courseId, order])
}

model Lesson {
  id          String     @id @default(cuid())
  slug        String?    @unique
  unitId      String
  unit        Unit       @relation(fields: [unitId], references: [id], onDelete: Cascade)
  order       Int
  title       String
  durationMin Int?
  isPreview   Boolean    @default(false)
  videoUrl    String?
  // For Phase 1, store the lesson's headline question content directly.
  // In later phases this becomes one Question among many.
  intro       String?    @db.Text
  blocks      Block[]
  questions   Question[]
  attempts    Attempt[]
  steps       LessonStep[]
  tutorSessions TutorSession[]
  chunks      LessonChunk[]
  progress    LessonProgress[]
  @@index([unitId, order])
}

/// A small searchable passage from the lesson's source material.
/// The `searchable` tsvector column + GIN index are added in the
/// migration's raw-SQL tail (Prisma doesn't model tsvector natively).
///
/// Citations in the AI tutor are produced by full-text searching
/// these rows for the student's question, then surfacing the matching
/// chunk's `page` number.
model LessonChunk {
  id        String   @id @default(cuid())
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  /// Page number in the source material (real textbook-style ref).
  page      Int
  /// Section label for richer citations, e.g. "Worked example" or "Definition".
  section   String?
  content   String   @db.Text
  createdAt DateTime @default(now())
  @@index([lessonId])
}

model LessonStep {
  id        String   @id @default(cuid())
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  order     Int
  title     String
  durationLabel String? // "2 min"
  isAi      Boolean  @default(false)
  @@index([lessonId, order])
}

model Block {
  id       String         @id @default(cuid())
  lessonId String
  lesson   Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  order    Int
  type     BlockType
  settings Json
  attempts Attempt[]
  votes    BlockVote[]
  comments BlockComment[]
  @@index([lessonId, order])
}

/// One comment per row, flat thread (no replies in v1). DISCUSSION
/// blocks host a class conversation about the lesson — public read so
/// every student sees the same thread, protected write so we have
/// authorship for moderation.
model BlockComment {
  id        String   @id @default(cuid())
  blockId   String
  block     Block    @relation(fields: [blockId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([blockId, createdAt])
  @@index([userId, createdAt])
}

/// One vote per (user, block) for POLL blocks. Unlike Attempt this is
/// not graded — POLL options have no correctness flag. `chosenKey`
/// mirrors the Attempt convention: stringified positional index into
/// settings.options. Upserted so students can change their vote.
model BlockVote {
  blockId   String
  block     Block    @relation(fields: [blockId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chosenKey String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@id([blockId, userId])
  @@index([blockId])
}

model Question {
  id         String     @id @default(cuid())
  lessonId   String
  lesson     Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  order      Int
  stem       String     @db.Text
  difficulty Int        @default(2)
  // answers shape: [{ key: "A", text: "7 slices", correct: false }, ...]
  answers    Json
  hints      Json?
  attempts   Attempt[]
  @@index([lessonId, order])
}

// ─────────────────────────── Skills ───────────────────────────

model Skill {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  // Visualization layout coords for the skill tree:
  col         Int
  row         Int
  isBoss      Boolean  @default(false)
  // Edges
  prereqs     SkillEdge[] @relation("PrereqOf")
  unlocks     SkillEdge[] @relation("Unlocks")
  mastery     Mastery[]
}

model SkillEdge {
  id        String @id @default(cuid())
  fromId    String
  toId      String
  from      Skill  @relation("Unlocks", fields: [fromId], references: [id], onDelete: Cascade)
  to        Skill  @relation("PrereqOf", fields: [toId], references: [id], onDelete: Cascade)
  @@unique([fromId, toId])
}

model Mastery {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillId   String
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  level     Float    // 0..1
  updatedAt DateTime @updatedAt
  @@id([userId, skillId])
}

// ─────────────────────────── Progress ───────────────────────────

model Enrollment {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId       String
  course         Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrolledAt     DateTime  @default(now())
  lastActivityAt DateTime?
  completed      Boolean   @default(false)
  progressPct    Int       @default(0)
  @@unique([userId, courseId])
  @@index([userId, lastActivityAt])
}

/// Per-(user, lesson) completion marker. Driven by `lesson.markComplete`
/// on the student client (the "Lesson complete →" button). The resolver
/// upserts a row here, then recomputes Enrollment.progressPct as
/// completed-lessons / total-lessons in the course so the dashboard +
/// library cards stay in sync.
model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())
  @@unique([userId, lessonId])
  @@index([userId, completedAt])
  @@index([lessonId])
}

model Attempt {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Exactly one of questionId / blockId is set: questionId for legacy
  // Question-based MCQs, blockId for MCQ blocks authored in the block
  // builder. Enforced at the app layer; Postgres has no CHECK constraint
  // in Prisma's schema DSL.
  questionId String?
  question   Question? @relation(fields: [questionId], references: [id], onDelete: Cascade)
  blockId    String?
  block      Block?    @relation(fields: [blockId], references: [id], onDelete: Cascade)
  lessonId   String
  lesson     Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  chosenKey  String?
  correct    Boolean
  hintsUsed  Int       @default(0)
  timeMs     Int
  createdAt  DateTime  @default(now())
  @@index([userId, createdAt])
  @@index([lessonId, createdAt])
  @@index([blockId, createdAt])
}

model XPEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  points    Int
  source    String
  refId     String?
  createdAt DateTime @default(now())
  @@index([userId, createdAt])
}

model Streak {
  userId    String    @id
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  current   Int       @default(0)
  longest   Int       @default(0)
  lastDay   DateTime?
  updatedAt DateTime  @updatedAt
}

model Badge {
  id    String      @id @default(cuid())
  slug  String      @unique
  name  String
  icon  String      // wf icon name
  rule  Json
  users UserBadge[]
}

model UserBadge {
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId  String
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  earnedAt DateTime @default(now())
  @@id([userId, badgeId])
}

// ─────────────────────────── Social / Commerce / Safety (Phase-1 light versions) ───────────────────────────

model Path {
  id        String       @id @default(cuid())
  slug      String       @unique
  title     String
  subtitle  String?      // "12 courses · 84 lessons"
  priceCents Int         @default(0)
  saveLabel  String?     // "Save 38%"
  courses   PathCourse[]
}

model PathCourse {
  pathId   String
  courseId String
  order    Int
  path     Path   @relation(fields: [pathId], references: [id], onDelete: Cascade)
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  @@id([pathId, courseId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  rating    Int
  body      String   @db.Text
  reviewerName  String?
  reviewerRole  String?
  createdAt DateTime @default(now())
  @@index([courseId, createdAt])
}

model Follow {
  followerId String
  follower   User   @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followedId String
  followed   User   @relation("Followed", fields: [followedId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  @@id([followerId, followedId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String
  title     String
  body      String?
  href      String?
  readAt    DateTime?
  createdAt DateTime @default(now())
  @@index([userId, createdAt])
}

/// One AI-tutor conversation, scoped to a user (+ optional lesson).
model TutorSession {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId  String?
  lesson    Lesson?        @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  messages  TutorMessage[]
  @@index([userId, lessonId, createdAt])
}

model TutorMessage {
  id         String       @id @default(cuid())
  sessionId  String
  session    TutorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  /// "user" | "assistant"
  role       String
  content    String       @db.Text
  citations  Json?
  createdAt  DateTime     @default(now())
  @@index([sessionId, createdAt])
}

/// One purchase. Created at checkout-session-start with status=PENDING,
/// flipped to PAID once Stripe (or demo flow) confirms payment, at which
/// point an Enrollment row is created. Stores both gross + net so the
/// teacher's earnings page can sum payouts correctly.
model Order {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation("OrderBuyer", fields: [userId], references: [id], onDelete: Cascade)
  courseId     String
  course       Course      @relation("OrderCourse", fields: [courseId], references: [id], onDelete: Cascade)
  /// Teacher who authored the course; denormalized so the earnings query stays simple.
  teacherId    String
  teacher      User        @relation("OrderTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  /// Gross amount the student paid (cents).
  grossCents   Int
  /// Lyceum take (15% default). Subtract from gross to get net.
  feeCents     Int
  /// Teacher's net (cents). grossCents - feeCents.
  netCents     Int
  currency     String      @default("usd")
  status       OrderStatus @default(PENDING)
  /// "stripe" or "demo".
  provider     String
  /// Stripe Checkout Session id, or "demo_<cuid>" in demo mode.
  externalId   String      @unique
  createdAt    DateTime    @default(now())
  paidAt       DateTime?
  refundedAt   DateTime?
  @@index([userId, createdAt])
  @@index([teacherId, status, createdAt])
  @@index([courseId, status])
}

enum OrderStatus {
  PENDING
  PAID
  REFUNDED
  FAILED
}

/// Parent ↔ student link (Phase 4). Each row links a PARENT user
/// to a STUDENT user they're responsible for. Admin-managed in v1
/// (Tier 2.3 forward plan); self-service linking via invite token
/// is a future enhancement.
///
/// Role enforcement is at the app layer — the admin mutation
/// validates parent.role=PARENT and child.role=STUDENT before
/// inserting. (Prisma can't model enum-valued FKs.)
model ParentChild {
  parentId  String
  parent    User     @relation("ParentLinks", fields: [parentId], references: [id], onDelete: Cascade)
  childId   String
  child     User     @relation("ChildLinks", fields: [childId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  @@id([parentId, childId])
  @@index([childId])
}

/// Idempotency log for incoming Stripe webhook events. The webhook
/// handler inserts a row keyed on Stripe's `event.id` BEFORE doing
/// any side effects; the unique constraint makes re-deliveries
/// short-circuit with HTTP 200 instead of re-processing. Doubles as
/// an audit trail — every webhook the platform has ever received
/// has a row here, ordered by receivedAt.
model StripeEvent {
  id         String   @id @default(cuid())
  /// Stripe's `event.id` (evt_…). Unique → dedup at insert time.
  eventId    String   @unique
  type       String
  receivedAt DateTime @default(now())
  @@index([type, receivedAt])
}

/// Per-teacher Stripe Connect Express account. Created when a teacher
/// starts onboarding. The actual KYC dance happens on Stripe's hosted
/// pages; we just store the account id + whether it's payouts-enabled.
model StripeAccount {
  id          String   @id @default(cuid())
  teacherId   String   @unique
  teacher     User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  /// Stripe Connect account id (acct_…). For demo accounts: "demo_<cuid>".
  externalId  String   @unique
  provider    String   @default("stripe")
  /// Stripe says we can pay this account out. Defaults true in demo mode.
  payoutsEnabled Boolean @default(false)
  /// Stripe says we can charge through this account. Defaults true in demo mode.
  chargesEnabled Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Generated AI insight for a teacher (per-course) or admin (per-institution).
/// Cached so we don't re-burn Claude tokens on every dashboard load —
/// nightly cron / on-demand refresh button writes new rows; readers
/// pick the freshest non-expired one for their scope.
model Insight {
  id        String   @id @default(cuid())
  /// "teacher" | "admin"
  audience  String
  /// "TEACHER:<userId>" or "ADMIN:<institutionId>"
  scope     String
  /// "PATTERN" | "OPPORTUNITY" | "AT_RISK" | "STRENGTH" | "WATCH" | "TEACHER"
  kind      String
  /// 1-sentence headline (what we display as the insight body).
  body      String   @db.Text
  /// Short action label (e.g. "Suggest fix", "Send nudge"). Nullable.
  cta       String?
  /// Generation metadata: input stats, mode (claude/demo), elapsedMs, etc.
  payload   Json
  createdAt DateTime @default(now())
  /// 24h after createdAt by default. Readers ignore rows past this.
  expiresAt DateTime
  @@index([audience, scope, expiresAt])
  @@index([scope, createdAt])
}

/// Background AI generation job. The full course-outline call exceeds
/// Hobby's 60s function timeout, so it's broken into chunks: chunk 0
/// generates the outline skeleton (units + lesson titles, no readings),
/// chunks 1..N each generate readingContent for one unit's lessons.
/// Upstash QStash drives the work — each webhook hit runs one chunk
/// and re-enqueues if more remain. Client polls `generator.getJob`
/// every 2s and hydrates the final `output` when status="succeeded".
///
/// `mode` is the provider that actually ran ("claude" | "openai" | "demo");
/// set after the first chunk runs, used for audit. `error` carries the
/// friendly failure message when status="failed".
model GenerationJob {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind        String
  status      String   @default("pending")
  step        String?
  progress    Int      @default(0)
  input       Json
  partial     Json?
  output      Json?
  mode        String?
  error       String?
  nextChunk   Int      @default(0)
  totalChunks Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([userId, createdAt])
  @@index([status, updatedAt])
}

/// Append-only audit log. Captures every AI call + sensitive mutation
/// for FERPA + retention purposes. Never delete rows from this table —
/// the data-retention cron rewrites them with `redactedAt` set instead.
model AuditLog {
  id        String   @id @default(cuid())
  /// Who triggered it. Null for system / cron events.
  actorId   String?
  /// "ai.tutor", "ai.course_outline", "ai.regenerate_unit",
  /// "ai.generate_questions", "ai.marketplace_search",
  /// "ai.suggest_fix", "ai.why_path", "auth.signup", etc.
  kind      String
  /// Sanitized JSON: input shape, output shape, model id, token counts.
  /// Never persist API keys or full system prompts here.
  payload   Json
  /// Convenience pointers for fast lookups; nullable.
  lessonId  String?
  courseId  String?
  createdAt DateTime @default(now())
  /// Set by the data-retention cron when content is scrubbed.
  redactedAt DateTime?
  @@index([actorId, createdAt])
  @@index([kind, createdAt])
  @@index([courseId, createdAt])
  @@index([lessonId, createdAt])
}
